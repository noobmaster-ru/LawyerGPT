# X5 LLM API (OpenAI-совместимый шлюз)
X5_API_BASE_URL=https://api.x5.example/v1
X5_API_KEY=your_x5_api_key_here
X5_MODEL=Qwen2.5-7B-AWQ

# PostgreSQL (поднимается docker-compose'ом в database/)
POSTGRES_USER=legal_user
POSTGRES_PASSWORD=secret_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legal_db
# либо одной строкой, тогда переменные выше игнорируются:
# DATABASE_URL=postgresql+psycopg2://legal_user:secret_password@localhost:5432/legal_db

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
