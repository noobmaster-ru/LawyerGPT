# --- LLM (OpenAI-совместимый эндпоинт: Ollama / vLLM / X5 контур) ---
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_MAX_MODEL_LEN=8000

# --- Эмбеддинги ---
# EMBEDDING_PROVIDER=local -> локальный SentenceTransformer (BGE-M3 и т.п.)
# EMBEDDING_PROVIDER=api   -> удалённый OpenAI-совместимый эндпоинт (тот же LLM_API_BASE_URL / LLM_API_KEY)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=64

# Для локального режима: mps (Apple Silicon) / cuda (NVIDIA) / cpu
EMBEDDING_DEVICE=mps

# --- Пример конфигурации для X5-контура ---
# LLM_API_BASE_URL=https://<x5-endpoint>/v1
# LLM_API_KEY=<ваш-токен>
# LLM_MODEL=<llm-из-каталога-x5>
# EMBEDDING_PROVIDER=api
# EMBEDDING_MODEL=x5/x5-airun-multilingual-e5-large-instruct
# EMBEDDING_DIM=1024

# --- Postgres (поднимается через docker compose) ---
POSTGRES_USER=legal_user
POSTGRES_PASSWORD=secret_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=legal_db

# --- Qdrant (поднимается через docker compose) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
